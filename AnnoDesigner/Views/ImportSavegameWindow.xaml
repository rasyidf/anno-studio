<ui:FluentWindow
    x:Class="AnnoDesigner.Views.ImportSavegameWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Import Anno 117 Savegame"
    Width="500"
    Height="360"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <DockPanel LastChildFill="True">
        <ui:TitleBar Title="Import Anno 117 Savegame"
                     CanMaximize="False"
                     ShowMinimize="False"
                     ShowMaximize="False"
                     DockPanel.Dock="Top" />

        <!-- Bottom buttons -->
        <ui:Card DockPanel.Dock="Bottom"
                 Padding="8"
                 HorizontalAlignment="Stretch">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button Grid.Column="1"
                           x:Name="ImportButton"
                           Appearance="Primary"
                           Content="Import"
                           MinWidth="100"
                           MinHeight="32"
                           Click="ImportButton_Click"
                           IsEnabled="{Binding CanImport}" />
                <Button Grid.Column="3"
                        x:Name="CancelButton"
                        Content="Cancel"
                        MinWidth="100"
                        MinHeight="32"
                        Click="CancelButton_Click" />
            </Grid>
        </ui:Card>

        <!-- Main content -->
        <StackPanel Margin="16" DockPanel.Dock="Top">
            <!-- File picker -->
            <TextBlock Text="Savegame File (.a8s):"
                       Margin="0,0,0,4" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FilePathTextBox"
                         Grid.Column="0"
                         IsReadOnly="True" />
                <ui:Button Grid.Column="2"
                           Content="Browse..."
                           Click="BrowseButton_Click" />
            </Grid>

            <!-- Session selector -->
            <TextBlock Text="Session:"
                       Margin="0,0,0,4" />
            <ComboBox x:Name="SessionComboBox"
                      Margin="0,0,0,12"
                      SelectionChanged="SessionComboBox_SelectionChanged" />

            <!-- Island selector -->
            <TextBlock Text="Island:"
                       Margin="0,0,0,4" />
            <ComboBox x:Name="IslandComboBox"
                      Margin="0,0,0,12" />
        </StackPanel>
    </DockPanel>
</ui:FluentWindow>
